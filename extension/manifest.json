{
  "manifest_version": 2,
  "name": "Locatone",
  "version": "1.0.0",
  "description": "Spoof browser geolocation, timezone, locale, and client-side IP geo lookups — with optional proxy for real IP matching.",
  "icons": {
    "48": "icons/icon-48.png",
    "96": "icons/icon-96.png"
  },
  "browser_action": {
    "default_icon": {
      "48": "icons/icon-48.png",
      "96": "icons/icon-96.png"
    },
    "default_title": "Locatone",
    "default_popup": "popup/popup.html"
  },
  "background": {
    "scripts": [
      "lib/parse-location.js",
      "lib/timezone.js",
      "lib/ip-mock.js",
      "background.js"
    ],
    "persistent": true
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content/content.js"],
      "run_at": "document_start",
      "all_frames": true
    }
  ],
  "permissions": [
    "storage",
    "proxy",
    "webRequest",
    "webRequestBlocking",
    "<all_urls>"
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "locatone@local",
      "strict_min_version": "109.0"
    }
  }
}
