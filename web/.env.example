# Optional overrides for Locatone public probes (all safe to expose).
# Defaults match the built-in values in src/lib/env.ts.

VITE_API_BASE_URL=https://ipwho.is
VITE_IPWHO_BASE=https://ipwho.is/
VITE_GEOJS_URL=https://get.geojs.io/v1/ip/geo.json
VITE_CLOUDFLARE_TRACE_URL=https://www.cloudflare.com/cdn-cgi/trace
VITE_SEEIP_URL=https://api.seeip.org/geoip
VITE_GEOIPLOOKUP_URL=https://json.geoiplookup.io/
VITE_STUN_URL=stun:stun.l.google.com:19302
